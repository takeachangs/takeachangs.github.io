---
/**
 * Standardized layout for redirecting pages to homepage sections
 * Used for projects, contact, and blog index pages
 */

interface Props {
  section: string; // The section ID to redirect to on the homepage
  displayText?: string; // Optional display text for the loading page
}

const { section, displayText = `Redirecting to ${section} section...` } = Astro.props;
const redirectUrl = `/#${section}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="refresh" content={`0;url=${redirectUrl}`}>
  <title>Redirecting...</title>
  <style>
    body {
      font-family: 'M PLUS 1m', monospace;
      font-weight: 300;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
      color: #333;
    }
    .redirect-container {
      text-align: center;
    }
    p {
      margin-bottom: 1rem;
    }
    a {
      color: #555;
      text-decoration: underline;
    }
    a:hover {
      color: #000;
    }
  </style>
</head>
<body>
  <div class="redirect-container">
    <p>{displayText}</p>
    <p><a href={redirectUrl}>Click here if you're not redirected automatically</a></p>
  </div>

  <script define:vars={{ redirectUrl }}>
    window.location.href = redirectUrl;
  </script>
</body>
</html>