---
import profileData from '../content/profile.json';
const { name } = profileData;
const { pathname } = Astro.url; // Get current path

// Helper to check if a link is active (or a parent path is active)
const isActive = (linkPath: string) => {
  if (linkPath === '/') return pathname === '/'; // Exact match for home
  return pathname.startsWith(linkPath); // Check if current path starts with link path
}
---
<nav class="sidebar">
  <h1><a href="/">{name}</a></h1>
  <ul>
    <li><a href="/" class:list={{ active: isActive('/') }}>about</a></li>
    <li><a href="/projects" class:list={{ active: isActive('/projects') }}>projects</a></li>
    <li><a href="/blog" class:list={{ active: isActive('/blog') }}>blog</a></li>
    <li><a href="/contact" class:list={{ active: isActive('/contact') }}>contact</a></li>
  </ul>
</nav>

<style>
  h1 {
    font-size: 1.5rem; /* Adjust size */
    margin-bottom: 2rem;
    font-weight: 300;
  }
  h1 a {
    color: inherit; /* Make name link same color as text */
    text-decoration: none;
  }
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    margin-bottom: 0.5rem;
  }
  a {
    text-decoration: none;
    color: #555;
    display: block; /* Make links easier to click */
  }
  a:hover {
    color: #000;
    text-decoration: none; /* Keep no underline on hover */
  }
  a.active {
    color: #000; /* Style for active link */
    font-weight: bold; /* Or other indication */
  }
</style>